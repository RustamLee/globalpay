{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.01 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "avg_over_time(k6_hot_account_success_rate[$__rate_interval])",
          "legendFormat": "success_rate",
          "refId": "A"
        }
      ],
      "title": "Success rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "expr": "avg_over_time(k6_hot_account_conflict_rate[$__rate_interval])",
          "legendFormat": "conflict_rate",
          "refId": "A"
        }
      ],
      "title": "Conflict rate (409)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "expr": "avg_over_time(k6_hot_account_lock_timeout_rate[$__rate_interval])",
          "legendFormat": "lock_timeout_rate",
          "refId": "A"
        }
      ],
      "title": "Lock timeout rate (503)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "text": "FAIL" },
                "1": { "color": "green", "text": "PASS" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal", "textMode": "value" },
      "targets": [
        {
          "expr": "(k6_http_req_duration_p95 < bool 2000) * (avg_over_time(k6_hot_account_success_rate[$__rate_interval]) > bool 0) * (avg_over_time(k6_http_req_failed[$__rate_interval]) < bool 0.95)",
          "legendFormat": "verdict",
          "refId": "A"
        }
      ],
      "title": "Threshold verdict",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        {
          "expr": "increase(k6_hot_account_success_count[$__interval])",
          "legendFormat": "success_count",
          "refId": "A"
        },
        {
          "expr": "increase(k6_hot_account_conflict_count[$__interval])",
          "legendFormat": "conflict_count",
          "refId": "B"
        },
        {
          "expr": "increase(k6_hot_account_lock_timeout_count[$__interval])",
          "legendFormat": "lock_timeout_count",
          "refId": "C"
        }
      ],
      "title": "Outcome count per interval",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 4 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs[$__rate_interval])) or sum(rate(k6_http_reqs_total[$__rate_interval]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ],
      "title": "Total RPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 4 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "HTTP req duration p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 11 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "expr": "avg_over_time(k6_http_req_failed[$__rate_interval]) or avg_over_time(k6_http_req_failed_rate[$__rate_interval])",
          "legendFormat": "http_req_failed",
          "refId": "A"
        }
      ],
      "title": "HTTP failed rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 11 },
      "id": 9,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        {
          "expr": "sum by (status) (increase(k6_http_reqs{test_type=\"hot-account-contention\"}[$__interval])) or sum by (status) (increase(k6_http_reqs_total{test_type=\"hot-account-contention\"}[$__interval]))",
          "legendFormat": "status={{status}}",
          "refId": "A"
        }
      ],
      "title": "HTTP status breakdown",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 11 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "expr": "sum(increase(k6_iterations[$__interval]))",
          "legendFormat": "iterations",
          "refId": "A"
        },
        {
          "expr": "sum(k6_vus)",
          "legendFormat": "active_vus",
          "refId": "B"
        }
      ],
      "title": "Test load (iterations and VUs)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["k6", "load-test", "hot-contention"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "k6 Hot Account Contention",
  "uid": "k6-hot-account-contention",
  "version": 1,
  "weekStart": ""
}

